<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:Viewer.Models"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Viewer.MainWindow"
        x:CompileBindings="False"
        Title="SQLite DB Viewer">

    <Window.Styles>
        <Style Selector="DataGridRow.matched">
            <Setter Property="Background" Value="#33228822" />
        </Style>
        <Style Selector="DataGridRow.unmatched">
            <Setter Property="Background" Value="#33882222" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *, 250" Margin="10">
        <!-- Top Panel: DB Loaders -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Name="BtnLoadDb1" Content="Load DB 1" Click="BtnLoadDb1_Click"/>
                    <TextBlock Name="TxtDb1Path" VerticalAlignment="Center" Text="No DB 1 loaded" Width="500" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Name="BtnLoadDb2" Content="Load DB 2" Click="BtnLoadDb2_Click"/>
                    <TextBlock Name="TxtDb2Path" VerticalAlignment="Center" Text="No DB 2 loaded" Width="500" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StackPanel>

            <Button Name="BtnOpenWizard" Grid.Column="1" Content="Generar DB desde carpeta..." Click="BtnOpenWizard_Click" VerticalAlignment="Top" Padding="15,5"/>
        </Grid>

        <!-- Middle Panel: Grids and Filters -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 5, *">
            
            <!-- Context 1 -->
            <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
                    <TextBlock Text="Filter 1:" VerticalAlignment="Center"/>
                    <ComboBox Name="CmbFilter1" SelectedIndex="0" SelectionChanged="CmbFilter1_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Matched Only"/>
                        <ComboBoxItem Content="Unmatched Only"/>
                    </ComboBox>
                </StackPanel>

                <DataGrid Name="Grid1" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionChanged="Grid1_SelectionChanged" LoadingRow="DataGrid_LoadingRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" />
                        <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" />
                        <DataGridTextColumn Header="Hash" Binding="{Binding Hash}" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Name="TxtStats1" Grid.Row="2" Margin="0,5,0,0" Text="0 items (0% matched)" FontWeight="Bold" Foreground="Gray" />
            </Grid>

            <GridSplitter Grid.Column="1" Background="Gray" ResizeDirection="Columns"/>

            <!-- Context 2 -->
            <Grid Grid.Column="2" RowDefinitions="Auto, *, Auto">
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,5">
                    <TextBlock Text="Filter 2:" VerticalAlignment="Center"/>
                    <ComboBox Name="CmbFilter2" SelectedIndex="0" SelectionChanged="CmbFilter2_SelectionChanged">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="Matched Only"/>
                        <ComboBoxItem Content="Unmatched Only"/>
                    </ComboBox>
                </StackPanel>

                <DataGrid Name="Grid2" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionChanged="Grid2_SelectionChanged" LoadingRow="DataGrid_LoadingRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*" />
                        <DataGridTextColumn Header="Size" Binding="{Binding FileSize}" />
                        <DataGridTextColumn Header="Hash" Binding="{Binding Hash}" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Name="TxtStats2" Grid.Row="2" Margin="0,5,0,0" Text="0 items (0% matched)" FontWeight="Bold" Foreground="Gray" />
            </Grid>
        </Grid>

        <!-- Bottom Panel: Images -->
        <Grid Grid.Row="2" ColumnDefinitions="*, 5, *" Margin="0,10,0,0">
            <Grid Grid.Column="0" RowDefinitions="*, Auto" Margin="0,0,5,0">
                <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1">
                    <Image Name="ImgPreview1" Stretch="Uniform"/>
                </Border>
                <TextBlock Name="TxtImgPath1" Grid.Row="1" Margin="0,5,0,0" TextWrapping="Wrap" Foreground="Gray" />
            </Grid>

            <Grid Grid.Column="2" RowDefinitions="*, Auto" Margin="5,0,0,0">
                <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1">
                    <Image Name="ImgPreview2" Stretch="Uniform"/>
                </Border>
                <TextBlock Name="TxtImgPath2" Grid.Row="1" Margin="0,5,0,0" TextWrapping="Wrap" Foreground="Gray" />
            </Grid>
        </Grid>
    </Grid>
</Window>
